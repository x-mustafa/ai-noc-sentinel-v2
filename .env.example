DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=tabadul_noc

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=change_this_to_a_random_string_at_least_32_chars_long
SESSION_HTTPS_ONLY=false
OUTBOUND_TLS_VERIFY=false
DB_AUTO_MIGRATE_ON_STARTUP=false
EMBEDDED_SCHEDULER_ENABLED=false
REDIS_URL=
LOGIN_RATE_LIMIT_MODE=memory
PASSWORD_MIN_LENGTH=12
LOGIN_WINDOW_SECONDS=900
LOGIN_MAX_ATTEMPTS=10

# ── Microsoft 365 — Graph API (app-only / client credentials) ──────────────────
# Azure Portal → App Registrations → your app → Overview
MS365_TENANT_ID=your-tenant-id-here
MS365_CLIENT_ID=your-client-id-here
# Azure Portal → App Registrations → your app → Certificates & secrets
MS365_CLIENT_SECRET=your-client-secret-here
# The shared NOC mailbox address (must exist in your tenant)
MS365_EMAIL=noc@your-domain.com
#
# Required API permissions (Application, with admin consent):
#   Mail.Send       — send emails from the NOC mailbox
#   Mail.ReadWrite  — read and manage inbox
